	<parameter name="kode" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT *
FROM karyawan
JOIN transaksi ON karyawan.id_akun = transaksi.id_karyawan
JOIN detail_transaksi ON transaksi.id_transaksi = detail_transaksi.id_transaksi
JOIN menu ON detail_transaksi.id_menu = menu.id_menu
JOIN rasa ON detail_transaksi.id_rasa = rasa.id_rasa
WHERE
detail_transaksi.id_transaksi = $P{kode}]]>
	</queryString>
