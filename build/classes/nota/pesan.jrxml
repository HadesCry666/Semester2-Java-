	<parameter name="kode" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT *
FROM karyawan
JOIN pesanan ON karyawan.id_akun = pesanan.id_karyawan
JOIN detail_pesanan ON pesanan.id_pesanan = detail_pesanan.id_pesanan
JOIN menu ON detail_pesanan.id_menu = menu.id_menu
JOIN rasa ON detail_pesanan.id_rasa = rasa.id_rasa
WHERE
detail_pesanan.id_pesanan = $P{kode}]]>
	</queryString>
